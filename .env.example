LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT_SECONDS=600
LLM_HTTP_MAX_RETRIES=2
OPENAI_API_KEY=replace-with-your-api-key
MAX_SCENARIO_VALIDATION_ATTEMPTS=3
MAX_TEST_GENERATION_ATTEMPTS=3
MAX_LLM_SCHEMA_REPAIR_ATTEMPTS=1
MAX_LLM_RESPONSE_PARSE_RETRIES=1
ARTIFACTS_DIR=artifacts
LOG_LEVEL=INFO
